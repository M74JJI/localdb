# LocalDB Hub Linux/VM execution environment
# Copy to .env on the Debian/Ubuntu VM and edit the host IP.

LOCALDB_HUB_ROOT=/opt/localdb-hub
LOCALDB_HUB_DATABASE_URL=file:/opt/localdb-hub/metadata/localdb-hub.sqlite

API_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000

LOCALDB_HUB_WEB_ORIGIN=http://LOCAL_VM_IP:3000
LOCALDB_HUB_INTERNAL_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://LOCAL_VM_IP:4000

LOCALDB_HUB_DOCKER_ENABLED=true
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Set this to the VM IP visible from your host/laptop.
LOCALDB_HUB_PUBLIC_HOST=LOCAL_VM_IP

LOCALDB_HUB_MASTER_KEY_PATH=/opt/localdb-hub/config/master.key

WORKER_POLL_MS=3000
