# LocalDB Hub local development environment

LOCALDB_HUB_ROOT=./storage
LOCALDB_HUB_DATABASE_URL=file:./storage/metadata/localdb-hub.sqlite

API_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000

# Browser origin allowed by the API in local development.
LOCALDB_HUB_WEB_ORIGIN=http://localhost:3000

# Frontend server-side API URL.
LOCALDB_HUB_INTERNAL_API_URL=http://localhost:4000

# Frontend browser API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Docker checks:
# On Windows local development, keep this false unless Docker Desktop/WSL socket access is configured.
# On Linux/Debian/Ubuntu VM/server, set it true.
LOCALDB_HUB_DOCKER_ENABLED=false
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Public host shown in LAN connection strings.
LOCALDB_HUB_PUBLIC_HOST=127.0.0.1

# Local secrets encryption.
# Dev default is generated by `bun run setup:dev`.
LOCALDB_HUB_MASTER_KEY_PATH=./storage/config/master.key
