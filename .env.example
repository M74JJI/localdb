# LocalDB Hub example environment
# Safe to commit to GitHub.
#
# This file contains only local development defaults and a private LAN test IP.
# It does NOT contain production secrets.
#
# For another machine, replace:
#   192.168.133.131
# with the IP returned by:
#   hostname -I

# -----------------------------------------------------------------------------
# Runtime storage
# -----------------------------------------------------------------------------

# Root folder for metadata, config, database files, backups, and runtime data.
LOCALDB_HUB_ROOT=./storage

# Local metadata database used by the LocalDB Hub control plane.
# SQLite file path is relative to the project root.
LOCALDB_HUB_DATABASE_URL=file:./storage/metadata/localdb-hub.sqlite

# Local encryption master key path.
# The real key file is generated by `bun run setup:dev`.
# Do not commit the generated key.
LOCALDB_HUB_MASTER_KEY_PATH=./storage/config/master.key

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------

# Bind to all interfaces so the Windows host/browser can reach the Ubuntu VM.
API_HOST=0.0.0.0
API_PORT=4000

# Browser origin allowed by the API in local development.
# Must match the URL used in the browser.
LOCALDB_HUB_WEB_ORIGIN=http://192.168.133.131:3000

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------

WEB_PORT=3000

# Server-side API URL used by Next.js server components.
# Keep this localhost when API and Web run on the same Ubuntu VM.
LOCALDB_HUB_INTERNAL_API_URL=http://localhost:4000

# Browser-side API URL used by client components.
# If you open the web app from Windows at http://192.168.133.131:3000,
# the browser must call the API at http://192.168.133.131:4000.
NEXT_PUBLIC_API_BASE_URL=http://192.168.133.131:4000

# -----------------------------------------------------------------------------
# Docker / Linux VM execution
# -----------------------------------------------------------------------------

# Linux/Debian/Ubuntu VM mode.
# Set false only for Windows local development without Docker socket access.
LOCALDB_HUB_DOCKER_ENABLED=true

# Default Docker socket path on Linux.
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Public host used in generated LAN connection strings.
LOCALDB_HUB_PUBLIC_HOST=192.168.133.131

# -----------------------------------------------------------------------------
# Security / session defaults
# -----------------------------------------------------------------------------

# Local development cookie name.
LOCALDB_HUB_SESSION_COOKIE=localdb_hub_session

# Cookie secure mode.
# Use false for local HTTP development.
# Use true only behind HTTPS.
LOCALDB_HUB_COOKIE_SECURE=false

# Optional session TTL in seconds.
# Default: 7 days.
LOCALDB_HUB_SESSION_TTL_SECONDS=604800

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------

# Worker polling interval in milliseconds.
LOCALDB_HUB_WORKER_POLL_MS=3000

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
#
# Typical Linux VM setup:
#
#   cp .env.example .env
#   bun run setup:dev
#   bun run db:generate
#   bun run db:push
#   bun run typecheck
#   bun run build
#
# Start services:
#
#   bun run dev:api
#   bun run dev:web
#   bun run dev:worker
#
# Test from Windows browser:
#
#   http://192.168.133.131:4000/api/setup/status
#   http://192.168.133.131:3000/setup
