# LocalDB Hub example environment
# Safe to commit to GitHub.
#
# This file contains only local development defaults and a private LAN test IP.
# It does NOT contain production secrets.
#
# Current Ubuntu VM test IP:
#   192.168.133.131
#
# For another machine, replace every occurrence of 192.168.133.131
# with the IP returned by:
#   hostname -I

# =============================================================================
# Runtime storage
# =============================================================================

LOCALDB_HUB_ROOT=./storage
LOCALDB_HUB_DATABASE_URL=file:./storage/metadata/localdb-hub.sqlite
LOCALDB_HUB_MASTER_KEY_PATH=./storage/config/master.key

# =============================================================================
# API server
# =============================================================================

API_HOST=0.0.0.0
API_PORT=4000
LOCALDB_HUB_WEB_ORIGIN=http://192.168.133.131:3000

# =============================================================================
# Web server
# =============================================================================

WEB_PORT=3000
LOCALDB_HUB_INTERNAL_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://192.168.133.131:4000

# Next.js dev server allowed origins for VM/LAN browser access.
# Required when opening the web app from Windows at the VM IP.
LOCALDB_HUB_ALLOWED_DEV_ORIGINS=192.168.133.131,192.168.133.131:3000,http://192.168.133.131:3000

# =============================================================================
# Docker / Linux VM execution
# =============================================================================

LOCALDB_HUB_DOCKER_ENABLED=true
DOCKER_SOCKET_PATH=/var/run/docker.sock
LOCALDB_HUB_PUBLIC_HOST=192.168.133.131

# =============================================================================
# Security / sessions
# =============================================================================

LOCALDB_HUB_SESSION_COOKIE=localdb_hub_session
LOCALDB_HUB_COOKIE_SECURE=false
LOCALDB_HUB_SESSION_TTL_SECONDS=604800

# =============================================================================
# Worker
# =============================================================================

LOCALDB_HUB_WORKER_POLL_MS=3000

# =============================================================================
# Development verification
# =============================================================================
#
# Recommended first setup:
#
#   cp .env.example .env
#   bun run setup:dev
#   bun run db:generate
#   bun run db:push
#   bun run typecheck
#   bun run build
#
# Start services:
#
#   bun run dev:api
#   bun run dev:web
#   bun run dev:worker
#
# Test API from Ubuntu:
#
#   curl http://localhost:4000/api/setup/status
#   curl http://192.168.133.131:4000/api/setup/status
#
# Test API from Windows browser:
#
#   http://192.168.133.131:4000/api/setup/status
#
# Test API CORS from Ubuntu:
#
#   curl -i \
#     -H "Origin: http://192.168.133.131:3000" \
#     http://192.168.133.131:4000/api/setup/status
#
# Expected CORS header:
#
#   access-control-allow-origin: http://192.168.133.131:3000
#
# Open web app:
#
#   http://192.168.133.131:3000/setup
